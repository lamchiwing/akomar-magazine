---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths(){

const brands = await getCollection("brands")

return brands.map((brand)=>({

params:{slug:brand.slug}

}))

}

const {slug}=Astro.params

const brands = await getCollection("brands")

const brand = brands.find(b=>b.slug===slug)
---

<BaseLayout title={brand.data.name}>

<section class="container article-wrap">

<article>

<header class="article-header">

<div class="tag">{brand.data.country}</div>

<h1>{brand.data.name}</h1>

<p class="excerpt">{brand.data.excerpt}</p>

<img src={brand.data.cover} alt={brand.data.name} />

</header>

<div class="prose">

<slot />

</div>

<div class="band">

<div class="eyebrow">品牌查詢</div>

<h3>有興趣了解此品牌？</h3>

<p class="muted">

歡迎提交查詢或訂閱最新品牌資訊。

</p>

<a class="button-solid" href="/enquiry">
提交查詢
</a>

</div>

</article>

</section>

</BaseLayout>
