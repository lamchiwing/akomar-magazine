---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../components/content.js";

const posts = getPublishedPosts();

const featured = posts[0];
const secondary = posts.slice(1, 4);

const beautyPosts = posts.filter((p) => ["品牌", "brands", "beauty"].includes((p.category || "").toLowerCase()) || (p.title || "").toLowerCase().includes("beauty")).slice(0, 4);
const foodPosts = posts.filter((p) => ["food", "食品", "歐洲美食"].includes((p.category || "").toLowerCase()) || (p.title || "").toLowerCase().includes("food")).slice(0, 4);
const travelPosts = posts.filter((p) => ["travel", "stories", "故事"].includes((p.category || "").toLowerCase())).slice(0, 4);
const healthPosts = posts.filter((p) => ["health", "wellness", "保健營養"].includes((p.category || "").toLowerCase()) || (p.title || "").toLowerCase().includes("wellness")).slice(0, 4);

const latestNews = posts.slice(0, 6);
const popularPosts = posts.slice(0, 5);
---

<BaseLayout
  title="AKOMARO Magazine"
  description="Curated European brands, product stories, and editorial collections."
  canonical="https://magazine.akomar.com/"
>
  <section class="trending-strip">
    <div class="container trending-inner">
      <div class="trending-label">TRENDING NOW</div>
      <div class="trending-text">
        {featured ? featured.title : "Curated European brands, collections, and stories"}
      </div>
    </div>
  </section>

  <section class="featured-hero">
    <div class="container">
      <div class="featured-grid">
        {featured && (
          <article class="featured-card featured-large">
            <a href={`/post/${featured.slug}`}>
              <img src={featured.cover || "/images/cover-automation.svg"} alt={featured.title} />
              <div class="featured-overlay">
                <div class="featured-tag">{featured.category || "Featured"}</div>
                <h2>{featured.title}</h2>
                <div class="featured-meta">
                  <span>{featured.author}</span>
                  <span>{featured.publish_at || featured.date}</span>
                </div>
              </div>
            </a>
          </article>
        )}

        {secondary.map((post) => (
          <article class="featured-card" key={post.slug}>
            <a href={`/post/${post.slug}`}>
              <img src={post.cover || "/images/cover-insights.svg"} alt={post.title} />
              <div class="featured-overlay">
                <div class="featured-tag">{post.category || "Feature"}</div>
                <h3>{post.title}</h3>
                <div class="featured-meta">
                  <span>{post.author}</span>
                  <span>{post.publish_at || post.date}</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="homepage-main">
    <div class="container content-with-sidebar">
      <div class="main-column">
        <section class="editorial-section">
          <div class="section-headline">
            <h2>BEAUTY & WELLNESS</h2>
          </div>

          <div class="section-split">
            {beautyPosts[0] && (
              <article class="lead-story">
                <img src={beautyPosts[0].cover || "/images/cover-asia.svg"} alt={beautyPosts[0].title} />
                <div class="mini-tag">{beautyPosts[0].category || "Beauty"}</div>
                <h3><a href={`/post/${beautyPosts[0].slug}`}>{beautyPosts[0].title}</a></h3>
                <div class="story-meta">
                  <strong>{beautyPosts[0].author}</strong>
                  <span>{beautyPosts[0].publish_at || beautyPosts[0].date}</span>
                </div>
                <p>{beautyPosts[0].excerpt}</p>
              </article>
            )}

            <div class="story-list">
              {beautyPosts.slice(1).map((post) => (
                <article class="story-list-item" key={post.slug}>
                  <img src={post.cover || "/images/cover-signals.svg"} alt={post.title} />
                  <div>
                    <h4><a href={`/post/${post.slug}`}>{post.title}</a></h4>
                    <div class="story-meta small-meta">
                      <span class="mini-tag">{post.category || "Beauty"}</span>
                      <span>{post.publish_at || post.date}</span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="editorial-section two-column-feature">
          <div class="section-headline">
            <h2>FOOD & DISCOVERY</h2>
          </div>

          <div class="dual-grid">
            <div>
              {foodPosts.slice(0, 2).map((post) => (
                <article class="stack-story" key={post.slug}>
                  <img src={post.cover || "/images/cover-signals.svg"} alt={post.title} />
                  <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
                  <div class="story-meta">
                    <strong>{post.author}</strong>
                    <span>{post.publish_at || post.date}</span>
                  </div>
                  <p>{post.excerpt}</p>
                </article>
              ))}
            </div>

            <div>
              {travelPosts.slice(0, 2).map((post) => (
                <article class="stack-story" key={post.slug}>
                  <img src={post.cover || "/images/cover-insights.svg"} alt={post.title} />
                  <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
                  <div class="story-meta">
                    <strong>{post.author}</strong>
                    <span>{post.publish_at || post.date}</span>
                  </div>
                  <p>{post.excerpt}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="editorial-section">
          <div class="section-headline">
            <h2>HEALTHY LIFE</h2>
          </div>

          <div class="grid-2-feature">
            {healthPosts.slice(0, 2).map((post) => (
              <article class="medium-feature" key={post.slug}>
                <img src={post.cover || "/images/cover-automation.svg"} alt={post.title} />
                <div class="mini-tag">{post.category || "Wellness"}</div>
                <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
                <div class="story-meta">
                  <strong>{post.author}</strong>
                  <span>{post.publish_at || post.date}</span>
                </div>
                <p>{post.excerpt}</p>
              </article>
            ))}
          </div>

          <div class="story-list-grid">
            {healthPosts.slice(2, 4).map((post) => (
              <article class="story-list-item horizontal" key={post.slug}>
                <img src={post.cover || "/images/cover-asia.svg"} alt={post.title} />
                <div>
                  <h4><a href={`/post/${post.slug}`}>{post.title}</a></h4>
                  <div class="story-meta small-meta">
                    <span class="mini-tag">{post.category || "Health"}</span>
                    <span>{post.publish_at || post.date}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside class="sidebar-column">
        <div class="social-boxes">
          <div class="social-box">
            <div class="social-icon">f</div>
            <strong>20,830</strong>
            <span>Fans</span>
          </div>
          <div class="social-box">
            <div class="social-icon">x</div>
            <strong>3,912</strong>
            <span>Followers</span>
          </div>
          <div class="social-box">
            <div class="social-icon">▶</div>
            <strong>22,200</strong>
            <span>Subscribers</span>
          </div>
        </div>

        <div class="ad-box">
          <div class="ad-inner">
            <span>300x250 Ad</span>
          </div>
        </div>

        <div class="sidebar-block">
          <h3>MOST POPULAR</h3>
          <div class="sidebar-list">
            {popularPosts.map((post) => (
              <article class="sidebar-post" key={post.slug}>
                <img src={post.cover || "/images/cover-insights.svg"} alt={post.title} />
                <div>
                  <h4><a href={`/post/${post.slug}`}>{post.title}</a></h4>
                  <div class="story-meta small-meta">
                    <span class="mini-tag">{post.category || "News"}</span>
                    <span>{post.publish_at || post.date}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="sidebar-block">
          <h3>LATEST NEWS</h3>
          <div class="sidebar-list">
            {latestNews.map((post) => (
              <article class="sidebar-post" key={post.slug}>
                <img src={post.cover || "/images/cover-signals.svg"} alt={post.title} />
                <div>
                  <h4><a href={`/post/${post.slug}`}>{post.title}</a></h4>
                  <div class="story-meta small-meta">
                    <span>{post.publish_at || post.date}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
