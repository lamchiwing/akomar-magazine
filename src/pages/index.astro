---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeaturedBrands from "../components/FeaturedBrands.astro";
import SubscribeCTA from "../components/SubscribeCTA.astro";
import { getPublishedPosts, getCategories } from "../components/content.js";

const posts = getPublishedPosts();

const featured = posts[0];
const latest = posts.slice(1, 5);
const gridPosts = posts.slice(0, 6);
const categories = getCategories();

const descriptions = {
  "brands": "精選歐洲品牌介紹、定位與視覺風格。",
  "stories": "品牌故事、工藝、產地與材料背景。",
  "collections": "季節系列、新品與精選產品展示。",
  "news": "最新上架、品牌動向、訂單開放與公告。",
  "asia-entry": "市場進場、品牌適配與區域導向內容。",
  "market-signals": "需求訊號、消費反應與價值感知。",
  "insights": "編輯觀察與策略分析。"
};
---

<BaseLayout
  title="AKOMAR European Brands"
  description="A curated platform introducing selected European brands, stories, and collections. Subscribe for updates or submit an enquiry."
  canonical="https://magazine.akomar.com/"
>
  <section class="hero">
    <div class="container hero-grid">
      <article class="hero-main">
        {featured?.cover && <img src={featured.cover} alt={featured.title} />}
        <div class="hero-copy">
          <div class="eyebrow">Curated European Brands</div>
          <div class="kicker">{featured?.category || "Featured Story"}</div>
          <h1>
            Discover selected European brands, stories, and collections for Asia-facing audiences.
          </h1>
          <p class="excerpt">
            這個網站主力展示歐洲品牌、品牌故事、產品系列與 editorial 內容，同時保留訂閱、查詢、訂單與 social media 分發能力。
          </p>
          <div class="meta">
            <span>{featured?.author || "AKOMAR 編輯部"}</span>
            <span>{featured?.publish_at || featured?.date || ""}</span>
          </div>
          <p style="margin-top:18px;">
            <a class="button-solid" href={featured ? `/post/${featured.slug}` : "#"}>閱讀精選內容</a>
          </p>
        </div>
      </article>

      <div class="hero-side">
        <div class="brief-card">
          <div class="eyebrow">網站定位</div>
          <h3>品牌展示、內容發佈、訂閱收集、訂單查詢</h3>
          <p class="muted">
            主站不再直接展示 automation 方案，但整體架構仍能支援 automation workflow，
            例如訂閱通知、social media 分發、order intake、品牌查詢與後台處理。
          </p>
        </div>

        <div class="brief-card">
          <div class="eyebrow">最新內容</div>
          <div class="list-stack">
            {latest.map((post) => (
              <div>
                <div class="kicker">{post.category}</div>
                <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
                <div class="meta">
                  <span>{post.author}</span>
                  <span>{post.publish_at || post.date}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="newsletter-card">
          <div class="eyebrow">Social Media Ready</div>
          <h3>適合內容分發、社交轉發與圖片展示</h3>
          <p class="muted">
            每篇文章頁保留分享按鈕與圖片位置，之後可接 Telegram、Threads、Instagram、Facebook 等自動分發流程。
          </p>
          <div class="form-row">
            <a class="button" href="#">查看最新系列</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FeaturedBrands />

  <section class="section">
    <div class="container home-split">
      <div>
        <div class="section-head">
          <div>
            <div class="eyebrow">Editorial Stories</div>
            <h2>故事與內容展示</h2>
          </div>
        </div>

        <div class="grid-3">
          {gridPosts.map((post) => (
            <article class="card">
              {post.cover && <img src={post.cover} alt={post.title} />}
              <div class="card-body">
                <div class="tag">{post.category}</div>
                <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
                <p class="excerpt">{post.excerpt}</p>
                <div class="meta">
                  <span>{post.author}</span>
                  <span>{post.publish_at || post.date}</span>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div>
        <div class="section-head">
          <div>
            <div class="eyebrow">Platform Focus</div>
            <h2>網站作用</h2>
          </div>
        </div>

        <div class="info-card">
          <div class="checklist">
            <div>展示歐洲品牌與品牌故事</div>
            <div>突出產品圖片與 editorial 內容</div>
            <div>收集訂閱者與品牌關注者</div>
            <div>收集訂單 / inquiry / wholesale enquiry</div>
            <div>可延伸接 social media automation</div>
          </div>
        </div>

        <div style="margin-top:16px;" class="band">
          <div class="eyebrow">內容分類</div>
          <div class="category-grid">
            {categories.map((category) => (
              <a class="category-box" href={`/category/${category.slug}`}>
                <div class="tag">{category.count} 篇</div>
                <h3>{category.name}</h3>
                <p class="excerpt">{descriptions[category.slug] || "分類頁面。"}</p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <SubscribeCTA />

  <section class="section">
    <div class="container">
      <div class="band">
        <div class="eyebrow">Image + Social + Automation Ready</div>
        <h3>保留圖片、社交媒體與後台 automation 擴充能力</h3>
        <p class="muted">
          雖然主頁不直接展示 automation 方案，但網站結構仍然很適合接：
          email 訂閱、自動社交分發、order routing、brand enquiry workflow、Telegram 推送與內容排程。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
