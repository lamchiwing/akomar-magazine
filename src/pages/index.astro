---
const siteUrl = "https://magazine.akomaro.com";
const defaultLang = "zh-hk";
const targetUrl = `${siteUrl}/${defaultLang}/`;
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=/${defaultLang}/`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>AKOMARO Magazine</title>
    <meta
      name="description"
      content="Curated European brands, stories, collections, and editorial content."
    />

    <link rel="canonical" href={targetUrl} />

    <link rel="alternate" hreflang="zh-hk" href={`${siteUrl}/zh-hk/`} />
    <link rel="alternate" hreflang="zh-cn" href={`${siteUrl}/zh-cn/`} />
    <link rel="alternate" hreflang="ja" href={`${siteUrl}/ja/`} />
    <link rel="alternate" hreflang="ko" href={`${siteUrl}/ko/`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/zh-hk/`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AKOMARO Magazine" />
    <meta property="og:title" content="AKOMARO Magazine" />
    <meta
      property="og:description"
      content="Curated European brands, stories, collections, and editorial content."
    />
    <meta property="og:url" content={targetUrl} />
    <meta property="og:image" content={`${siteUrl}/images/og-default.svg`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="AKOMARO Magazine" />
    <meta
      name="twitter:description"
      content="Curated European brands, stories, collections, and editorial content."
    />
    <meta name="twitter:image" content={`${siteUrl}/images/og-default.svg`} />
  </head>

  <body style="font-family: Arial, sans-serif; padding: 40px; text-align: center;">
    <h1>AKOMARO Magazine</h1>
    <p>Redirecting to the main language version...</p>
    <p>
      If you are not redirected automatically,
      <a href={`/${defaultLang}/`}>click here</a>.
    </p>
  </body>
</html>
