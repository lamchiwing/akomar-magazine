---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const brands = await getCollection("brands");
---

<BaseLayout title="歐洲品牌">

<section class="section">

<div class="container">

<div class="section-head">
<div>
<div class="eyebrow">European Brands</div>
<h1>精選歐洲品牌</h1>
<p class="excerpt">
本平台精選來自歐洲的品牌與產品系列。
</p>
</div>
</div>

<div class="grid-3">

{brands.map((brand)=> (

<article class="card">

<img src={brand.data.cover} alt={brand.data.name} />

<div class="card-body">

<div class="tag">{brand.data.country}</div>

<h3>
<a href={`/brand/${brand.slug}`}>
{brand.data.name}
</a>
</h3>

<p class="excerpt">{brand.data.excerpt}</p>

</div>

</article>

))}

</div>

</div>

</section>

</BaseLayout>
