---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getAllPosts, getAlternates } from "../../../components/content.js";

export async function getStaticPaths() {
  const posts = getAllPosts();

  return posts.map((post) => ({
    params: {
      lang: post.lang,
      slug: post.slug
    }
  }));
}

const { lang, slug } = Astro.params;
const posts = getAllPosts();
const post = posts.find((item) => item.slug === slug && item.lang === lang);

if (!post) throw new Error(`Post not found: ${lang}/${slug}`);

const baseUrl = "https://magazine.akomaro.com";
const canonical = `${baseUrl}/${lang}/post/${slug}`;
const alternates = getAlternates("post", post.original_slug);
const ogImage = post.og_image || post.cover || "/images/og-default.svg";
---

<BaseLayout
  title={post.seo_title || post.title}
  description={post.seo_description || post.excerpt}
  canonical={canonical}
  image={ogImage}
  lang={lang}
>
  <Fragment slot="head">
    {alternates.map((item) => (
      <link rel="alternate" hreflang={item.lang} href={`${baseUrl}/${item.lang}/post/${item.slug}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}/zh-hk/post/${post.slug}`} />
    <meta property="og:type" content="article" />
  </Fragment>

  <article class="container" style="padding:32px 0;">
    <h1>{post.title}</h1>
    <div class="prose" set:html={post.body_html}></div>
  </article>
</BaseLayout>
