---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SUPPORTED_LANGS } from "../../../components/content.js";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const endpoint = "YOUR_APPS_SCRIPT_WEB_APP_URL";

const copy = {
  "zh-hk": {
    title: "查詢",
    name: "姓名",
    email: "電郵",
    company: "公司",
    country: "國家 / 地區",
    brand: "品牌代號",
    type: "查詢類型",
    message: "留言內容",
    submit: "提交",
    success: "已成功提交。",
    fail: "提交失敗。"
  },
  "zh-cn": {
    title: "咨询",
    name: "姓名",
    email: "邮箱",
    company: "公司",
    country: "国家 / 地区",
    brand: "品牌代号",
    type: "咨询类型",
    message: "留言内容",
    submit: "提交",
    success: "已成功提交。",
    fail: "提交失败。"
  },
  "ja": {
    title: "お問い合わせ",
    name: "お名前",
    email: "メール",
    company: "会社名",
    country: "国 / 地域",
    brand: "ブランドスラッグ",
    type: "お問い合わせ種別",
    message: "メッセージ",
    submit: "送信",
    success: "送信されました。",
    fail: "送信に失敗しました。"
  },
  "ko": {
    title: "문의",
    name: "이름",
    email: "이메일",
    company: "회사명",
    country: "국가 / 지역",
    brand: "브랜드 슬러그",
    type: "문의 유형",
    message: "메시지",
    submit: "제출",
    success: "제출되었습니다.",
    fail: "제출에 실패했습니다."
  }
};

const t = copy[lang] || copy["zh-hk"];
---

<BaseLayout
  title={`${t.title} | AKOMARO`}
  description="Submit wholesale, partnership, or brand enquiry."
  canonical={`https://magazine.akomaro.com/${lang}/enquiry/`}
  lang={lang}
>
  <section class="container" style="padding:32px 0;">
    <h1>{t.title}</h1>

    <form id="enquiry-form" class="card-body" style="max-width:720px;">
      <input name="name" placeholder={t.name} required />
      <input name="email" type="email" placeholder={t.email} required />
      <input name="company" placeholder={t.company} />
      <input name="country" placeholder={t.country} />
      <input name="brand_slug" placeholder={t.brand} />
      <input name="interest_type" placeholder={t.type} />
      <textarea name="message" placeholder={t.message} rows="6"></textarea>
      <button type="submit">{t.submit}</button>
      <p id="form-status"></p>
    </form>
  </section>

  <script define:vars={{ endpoint, lang, successText: t.success, failText: t.fail }}>
    const form = document.getElementById("enquiry-form");
    const status = document.getElementById("form-status");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());
      payload.lang = lang;
      payload.source = "website";
      payload.page_url = window.location.href;

      try {
        const res = await fetch(endpoint, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        const json = await res.json();
        status.textContent = json.ok ? successText : failText;
      } catch (err) {
        status.textContent = failText;
      }
    });
  </script>
</BaseLayout>
