---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SUPPORTED_LANGS, getPublishedBrands } from "../../../components/content.js";

export function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const brands = getPublishedBrands(lang);

const copy = {
  "zh-hk": {
    title: "品牌",
    empty: "暫時未有品牌內容。"
  },
  "zh-cn": {
    title: "品牌",
    empty: "暂时没有品牌内容。"
  },
  "ja": {
    title: "ブランド",
    empty: "まだブランドコンテンツがありません。"
  },
  "ko": {
    title: "브랜드",
    empty: "아직 브랜드 콘텐츠가 없습니다."
  }
};

const t = copy[lang] || copy["zh-hk"];
const baseUrl = "https://magazine.akomaro.com";
---

<BaseLayout
  title={`${t.title} | AKOMARO`}
  description="European brands directory."
  canonical={`${baseUrl}/${lang}/brands/`}
  lang={lang}
>
  <section class="container" style="padding:32px 0;">
    <h1>{t.title}</h1>

    {brands.length ? (
      <div class="grid-3">
        {brands.map((brand) => (
          <article class="card">
            {brand.cover && <img src={brand.cover} alt={brand.name || brand.title} />}
            <div class="card-body">
              <h2>
                <a href={`/${lang}/brand/${brand.slug}`}>
                  {brand.name || brand.title}
                </a>
              </h2>
              {brand.excerpt && <p>{brand.excerpt}</p>}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <p>{t.empty}</p>
    )}
  </section>
</BaseLayout>
