---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  SUPPORTED_LANGS,
  getPublishedPosts,
  getPublishedPostBySlug,
  getAlternates,
  slugifyCategory
} from "../../../../components/content.js";

export function getStaticPaths() {
  const paths = [];
  for (const lang of SUPPORTED_LANGS) {
    for (const post of getPublishedPosts(lang)) {
      paths.push({ params: { lang, slug: post.slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const post = getPublishedPostBySlug(lang, slug);
if (!post) throw new Error("Post not found");

const related = getPublishedPosts(lang)
  .filter((item) => item.slug !== post.slug && item.category === post.category)
  .slice(0, 4);

const baseUrl = "https://magazine.akomaro.com";
const canonical = `${baseUrl}/${lang}/post/${post.slug}`;
const alternates = getAlternates("post", post.original_slug);

const langMap = {
  "zh-hk": "zh-Hant",
  "zh-cn": "zh-Hans",
  "ja": "ja",
  "ko": "ko"
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.seo_title || post.title,
  description: post.seo_description || post.excerpt,
  image: post.og_image ? [`${baseUrl}${post.og_image}`] : [],
  author: { "@type": "Person", name: post.author },
  datePublished: post.publish_at || post.date,
  mainEntityOfPage: canonical
};
---

<BaseLayout
  title={`${post.seo_title || post.title} | AKOMARO Magazine`}
  description={post.seo_description || post.excerpt}
  image={post.og_image || post.cover}
  canonical={canonical}
  lang={langMap[lang] || "en"}
>
  <Fragment slot="head">
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.lang} href={`${baseUrl}/${alt.lang}/post/${alt.slug}`} />
    ))}
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>

  <section class="container article-wrap">
    <article>
      <div class="tag">
        <a href={`/${lang}/category/${slugifyCategory(post.category)}`}>{post.category}</a>
      </div>
      <h1>{post.title}</h1>
      <p class="excerpt">{post.excerpt}</p>

      {post.cover && <img src={post.cover} alt={post.title} />}

      <div class="prose" set:html={post.body}></div>

      {(post.sponsor || post.cta_text || post.cta_link) && (
        <div class="band">
          <div class="eyebrow">{post.sponsor ? `Sponsored: ${post.sponsor}` : "Featured"}</div>
          <h3>{post.cta_text || "Explore More"}</h3>
          {post.cta_link && (
            <p><a class="button-solid" href={post.cta_link} target="_blank" rel="noreferrer">Open Link</a></p>
          )}
        </div>
      )}
    </article>

    <aside class="sidebar">
      <h3>Related</h3>
      {related.map((item) => (
        <div class="related-item">
          <a href={`/${lang}/post/${item.slug}`}>{item.title}</a>
        </div>
      ))}
    </aside>
  </section>
</BaseLayout>
