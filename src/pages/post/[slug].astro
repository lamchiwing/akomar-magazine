---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPublishedPosts } from "../../components/content.js";

export async function getStaticPaths() {
  const posts = getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.slug }
  }));
}

const { slug } = Astro.params;

const posts = getPublishedPosts();
const post = posts.find(p => p.slug === slug);

if (!post) {
  throw new Error("Post not found");
}

const publishTime = new Date(post.publish_at || post.date);
if (publishTime > new Date()) {
  throw new Error("Post not published yet");
}

/* helper */
function slugifyCategory(cat) {
  return (cat || "")
    .toLowerCase()
    .replace(/\s+/g, "-");
}

/* share */
const shareUrl = `https://magazine.akomar.com/post/${post.slug}`;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(post.title);

/* related */
const related = posts
  .filter(p => p.slug !== post.slug && p.category === post.category)
  .slice(0, 4);

/* schema */
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.title,
  description: post.excerpt,
  image: post.cover,
  author: {
    "@type": "Person",
    name: post.author
  },
  datePublished: post.publish_at || post.date
};
---

<BaseLayout
  title={`${post.title} | AKOMARO Magazine`}
  description={post.excerpt}
  image={post.cover}
  canonical={shareUrl}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <section class="container article-wrap">
    <article>
      <header class="article-header">
        <div class="tag">
          <a href={`/category/${slugifyCategory(post.category)}`}>
            {post.category}
          </a>
        </div>

        <h1>{post.title}</h1>
        <p class="excerpt">{post.excerpt}</p>

        <div class="meta">
          <span>{post.author}</span>
          <span>{post.publish_at || post.date}</span>
        </div>

        {post.cover && (
          <figure class="cover">
            <img src={post.cover} alt={post.title} />
          </figure>
        )}

        <div class="share-links">
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`} target="_blank">Facebook</a>
          <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`} target="_blank">LinkedIn</a>
          <a href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`} target="_blank">Telegram</a>
        </div>
      </header>

      <div class="prose" set:html={post.body}></div>
    </article>

    <aside class="sidebar">
      <div class="sidebar-card">
        <h3>Related Articles</h3>

        {related.map((item) => (
          <div class="related-item">
            <h4><a href={`/post/${item.slug}`}>{item.title}</a></h4>
          </div>
        ))}
      </div>
    </aside>
  </section>
</BaseLayout>
