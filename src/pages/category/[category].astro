---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllPosts } from "../../components/content.js";

export async function getStaticPaths() {
  const posts = getAllPosts();

  const categories = [...new Set(posts.map(p =>
    p.category.toLowerCase().replace(/\s+/g, "-")
  ))];

  return categories.map((category) => ({
    params: { category }
  }));
}

const { category } = Astro.params;

const posts = getAllPosts()
  .filter((post) => {
    const slug = post.category.toLowerCase().replace(/\s+/g, "-");

    const publishTime = new Date(post.publish_at || post.date);

    return slug === category && publishTime <= new Date();
  })
  .sort((a, b) =>
    new Date(b.publish_at || b.date) -
    new Date(a.publish_at || a.date)
  );
---
<BaseLayout
  title={`${category.name} | AKOMAR Automation Magazine`}
  description={descriptions[category.slug] || "內容分類頁。"}
  canonical={`https://magazine.akomar.com/category/${category.slug}`}
>
  <section class="section">
    <div class="container">
      <div class="eyebrow">Category</div>
      <h1>{category.name}</h1>
      <p class="excerpt">{descriptions[category.slug] || "內容分類頁。"}</p>
      <div style="margin-top:24px;" class="list-stack">
        {posts.map((post) => (
          <article class="list-card">
            {post.cover && <img src={post.cover} alt={post.title} />}
            <div class="card-body">
              <div class="tag">{post.category}</div>
              <h3><a href={`/post/${post.slug}`}>{post.title}</a></h3>
              <p class="excerpt">{post.excerpt}</p>
              <div class="meta"><span>{post.author}</span><span>{post.date}</span></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
