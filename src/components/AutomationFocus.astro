---
const layers = [
  { title: "Automation Basic", price: "€99 / month", text: "適合剛開始整理 enquiry 的品牌，先把無效查詢與基本 routing 做好。" },
  { title: "Automation Pro", price: "€129 / month", text: "加入 lead scoring、automatic email routing、history record，適合 enquiry 變多的階段。" },
  { title: "Automation Plus", price: "€159 / month", text: "加入 distributor screening 與 contact verification，適合開始尋找代理或分銷方。" },
  { title: "Automation Advanced", price: "€199 / month", text: "更完整的分流、篩選與市場前線控制，適合已開始建立亞洲渠道的品牌。" }
];
---
<section class="section">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">Automation Focus</div>
        <h2>更迎合 automation 的首頁內容</h2>
        <p class="excerpt">這個最終版本已把首頁重心放在 automation、routing、enquiry control 及語言加購展示。</p>
      </div>
    </div>
    <div class="grid-4">
      {layers.map((item) => (
        <article class="automation-box">
          <div class="kicker">{item.price}</div>
          <h3>{item.title}</h3>
          <p class="excerpt">{item.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
