---
const brands = [
  {
    name: "Nordic Scent House",
    country: "瑞典",
    image: "/images/cover-insights.svg",
    text: "以北歐極簡美學與自然香氣為核心的生活風格香氛品牌。"
  },
  {
    name: "Maison Botanique",
    country: "法國",
    image: "/images/cover-asia.svg",
    text: "結合植物、生活風格與視覺美感的歐洲 wellness 品牌。"
  },
  {
    name: "Atelier Terra",
    country: "意大利",
    image: "/images/cover-signals.svg",
    text: "以地中海生活與工藝質感為靈感的設計與家居品牌。"
  },
  {
    name: "Baltic Heritage Silver",
    country: "芬蘭",
    image: "/images/cover-automation.svg",
    text: "強調手工藝、材質與禮品屬性的銀飾與設計選品。"
  }
];
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">Featured Brands</div>
        <h2>精選歐洲品牌</h2>
        <p class="excerpt">
          透過圖片、文字與 editorial 方式展示品牌背景、產地與產品特色。
        </p>
      </div>
    </div>

    <div class="grid-4">
      {brands.map((brand) => (
        <article class="card">
          <img src={brand.image} alt={brand.name} />
          <div class="card-body">
            <div class="tag">{brand.country}</div>
            <h3>{brand.name}</h3>
            <p class="excerpt">{brand.text}</p>
            <p style="margin-top:12px;">
              <a class="button" href="#">查看品牌</a>
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
