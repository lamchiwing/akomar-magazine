---
const brands = [
  {
    name: "Nordic Scent House",
    country: "Sweden",
    image: "/images/cover-insights.svg",
    text: "Scandinavian lifestyle fragrance with a clean visual identity, suitable for curated retail and gifting channels."
  },
  {
    name: "Maison Botanique",
    country: "France",
    image: "/images/cover-asia.svg",
    text: "A botanical-led wellness label built around origin stories, refined packaging, and seasonal collections."
  },
  {
    name: "Atelier Terra",
    country: "Italy",
    image: "/images/cover-signals.svg",
    text: "Mediterranean-inspired craft products with strong material storytelling and premium lifestyle positioning."
  },
  {
    name: "Baltic Heritage Silver",
    country: "Finland",
    image: "/images/cover-automation.svg",
    text: "Small-batch silver and design-led accessories with artisan appeal and gift-ready presentation."
  }
];
---

<section class="section">
  <div class="container">
    <div class="section-head">
      <div>
        <div class="eyebrow">Featured Brands</div>
        <h2>精選歐洲品牌</h2>
        <p class="excerpt">
          以 editorial 形式展示品牌背景、視覺、產地與產品故事，同時保留之後接 automation inquiry flow 的空間。
        </p>
      </div>
    </div>

    <div class="grid-4">
      {brands.map((brand) => (
        <article class="card">
          <img src={brand.image} alt={brand.name} />
          <div class="card-body">
            <div class="tag">{brand.country}</div>
            <h3>{brand.name}</h3>
            <p class="excerpt">{brand.text}</p>
            <p style="margin-top:12px;">
              <a class="button" href="#">查看品牌</a>
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
