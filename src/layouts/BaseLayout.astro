---
import "../styles/global.css";

const {
  title = "AKOMARO European Brands",
  description = "A curated platform introducing selected European brands, stories, and collections. Subscribe for updates or submit an enquiry.",
  image = "/images/og-default.svg",
  canonical = "https://magazine.akomar.com/"
} = Astro.props;
---
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="AKOMAR European Brands" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={image.startsWith("http") ? image : `https://magazine.akomar.com${image}`} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image.startsWith("http") ? image : `https://magazine.akomar.com${image}`} />
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="/" class="brand">AKOMAR</a>

      <nav class="nav">
        <a href="/">首頁</a>
        <a href="/category/brands">品牌</a>
        <a href="/category/stories">故事</a>
        <a href="/category/collections">系列</a>
        <a href="/category/news">最新消息</a>
      </nav>

      <div class="social-mini">
        <a href="https://facebook.com/" target="_blank" rel="noreferrer">Facebook</a>
        <a href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
        <a href="https://threads.net/" target="_blank" rel="noreferrer">Threads</a>
        <a href="https://t.me/" target="_blank" rel="noreferrer">Telegram</a>
      </div>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <div class="brand" style="font-size:1rem;">AKOMAR</div>
        <p>
          A curated platform introducing selected European brands, stories, and collections.
          Built to support subscription growth, enquiry capture, and order intake through a
          cleaner editorial experience.
        </p>

        <div class="footer-nav">
          <a href="/">首頁</a>
          <a href="/category/brands">品牌</a>
          <a href="/category/stories">故事</a>
          <a href="/category/collections">系列</a>
          <a href="/category/news">最新消息</a>
        </div>
      </div>

      <div>
        <div class="eyebrow">社交連結</div>
        <div class="footer-social">
          <a href="https://facebook.com/" target="_blank" rel="noreferrer">Facebook</a>
          <a href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
          <a href="https://threads.net/" target="_blank" rel="noreferrer">Threads</a>
          <a href="https://t.me/" target="_blank" rel="noreferrer">Telegram</a>
          <a href="https://linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
