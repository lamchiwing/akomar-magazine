---
import "../styles/global.css";

const {
  title = "AKOMARO Magazine",
  description = "Curated European brands, stories, and collections.",
  image = "/images/og-default.svg",
  canonical = "https://magazine.akomaro.com/",
  lang = "zh-Hant"
} = Astro.props;
---
<html lang={lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="AKOMARO Magazine" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={image.startsWith("http") ? image : `https://magazine.akomaro.com${image}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image.startsWith("http") ? image : `https://magazine.akomaro.com${image}`} />
  <slot name="head" />
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="/zh-hk/">AKOMARO Magazine</a>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>AKOMARO Magazine — curated European brands, stories, and collections.</p>
    </div>
  </footer>
</body>
</html>
