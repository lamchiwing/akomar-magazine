---
import "../styles/global.css";
const {
  title = "AKOMAR Automation Magazine",
  description = "繁體中文為主的 automation-friendly magazine site，結合文章、分類、社交分享及語言加購展示。",
  image = "/images/og-default.svg",
  canonical = "https://magazine.akomar.com/"
} = Astro.props;
---
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="AKOMAR Automation Magazine" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={image.startsWith("http") ? image : `https://magazine.akomar.com${image}`} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image.startsWith("http") ? image : `https://magazine.akomar.com${image}`} />
</head>
<body>
  <header class="topbar">
    <div class="container topbar-inner">
      <a href="/" class="brand">AKOMAR</a>
      <nav class="nav">
        <a href="/">首頁</a>
        <a href="/category/automation">Automation</a>
        <a href="/category/asia-entry">亞洲進場</a>
        <a href="/category/market-signals">市場訊號</a>
        <a href="/category/insights">洞察</a>
      </nav>
      <div class="social-mini">
        <a href="https://facebook.com/" target="_blank" rel="noreferrer">Facebook</a>
        <a href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
        <a href="https://threads.net/" target="_blank" rel="noreferrer">Threads</a>
        <a href="https://t.me/" target="_blank" rel="noreferrer">Telegram</a>
      </div>
    </div>
  </header>
  <main><slot /></main>
  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <div class="brand" style="font-size:1rem;">AKOMAR</div>
        <p>以 automation 為重心的雜誌式網站 starter，適合每日發文、展示產品、加購語言，以及之後交由同事負責內容更新。</p>
        <div class="footer-nav">
          <a href="/">首頁</a>
          <a href="/category/automation">Automation</a>
          <a href="/category/asia-entry">亞洲進場</a>
          <a href="/category/market-signals">市場訊號</a>
          <a href="/category/insights">洞察</a>
        </div>
      </div>
      <div>
        <div class="eyebrow">社交連結</div>
        <div class="footer-social">
          <a href="https://facebook.com/" target="_blank" rel="noreferrer">Facebook</a>
          <a href="https://instagram.com/" target="_blank" rel="noreferrer">Instagram</a>
          <a href="https://threads.net/" target="_blank" rel="noreferrer">Threads</a>
          <a href="https://t.me/" target="_blank" rel="noreferrer">Telegram</a>
          <a href="https://linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
